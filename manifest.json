{
  "schemaVersion": "scum-plugin.v1",
  "pluginId": "scum-admin",
  "name": "SCUM Admin",
  "version": "0.1.8",
  "channel": "stable",
  "compatibility": {
    "minScumServerVersion": "1.0.0",
    "maxScumServerVersion": "2.0.0"
  },
  "runtime": {
    "image": "npc0/scum-admin-plugin:v0.1.8",
    "internalPorts": [],
    "exposedPorts": [],
    "portMappings": [],
    "mounts": [],
    "privileged": false,
    "hostNetwork": false
  },
  "capabilities": [
    {
      "key": "artifact.read",
      "version": "1",
      "riskLevel": "low"
    },
    {
      "key": "db.query",
      "version": "1",
      "riskLevel": "medium",
      "parameters": {
        "execution": "bound-run-endpoint",
        "databaseRef": "scum-main",
        "readOnly": true,
        "maxRows": 500,
        "maxBytes": 1048576
      }
    },
    {
      "key": "file.read",
      "version": "1",
      "riskLevel": "medium"
    },
    {
      "key": "file.patch",
      "version": "1",
      "riskLevel": "high"
    },
    {
      "key": "process.control",
      "version": "1",
      "riskLevel": "high"
    },
    {
      "key": "steam.news",
      "version": "1",
      "riskLevel": "low"
    },
    {
      "key": "steamcmd.update",
      "version": "1",
      "riskLevel": "high"
    },
    {
      "key": "task.query",
      "version": "1",
      "riskLevel": "medium"
    },
    {
      "key": "task.run",
      "version": "1",
      "riskLevel": "high"
    }
  ],
  "permissions": [
    {
      "key": "scum.config.read",
      "riskLevel": "medium",
      "description": "读取实例范围内的 WindowsServer 配置目录，并支持完整的 SCUM 常用配置文件集合。",
      "parameters": {
        "directory": "SCUM/Saved/Config/WindowsServer",
        "preferredFile": "SCUM/Saved/Config/WindowsServer/ServerSettings.ini",
        "supportedFiles": [
          "SCUM/Saved/Config/WindowsServer/AdminUsers.ini",
          "SCUM/Saved/Config/WindowsServer/BannedUsers.ini",
          "SCUM/Saved/Config/WindowsServer/EconomyOverride.json",
          "SCUM/Saved/Config/WindowsServer/ExclusiveUsers.ini",
          "SCUM/Saved/Config/WindowsServer/GameUserSettings.ini",
          "SCUM/Saved/Config/WindowsServer/Input.ini",
          "SCUM/Saved/Config/WindowsServer/Input.ini.bak",
          "SCUM/Saved/Config/WindowsServer/Notifications.json",
          "SCUM/Saved/Config/WindowsServer/RaidTimes.json",
          "SCUM/Saved/Config/WindowsServer/ServerSettings.ini",
          "SCUM/Saved/Config/WindowsServer/ServerSettingsAdminUsers.ini",
          "SCUM/Saved/Config/WindowsServer/SilencedUsers.ini",
          "SCUM/Saved/Config/WindowsServer/WhitelistedUsers.ini"
        ]
      }
    },
    {
      "key": "scum.config.patch",
      "riskLevel": "high",
      "description": "通过受控 diff 修改实例范围内的 SCUM ServerSettings.ini 配置。",
      "parameters": {
        "path": "SCUM/Saved/Config/WindowsServer/ServerSettings.ini",
        "requiresChecksum": true
      }
    },
    {
      "key": "scum.database.query",
      "riskLevel": "medium",
      "description": "提交实例绑定 SCUM.db 的只读查询计划；查询只能由绑定 run 执行端执行。",
      "parameters": {
        "databaseRef": "scum-main",
        "readOnly": true,
        "execution": "bound-run-endpoint"
      }
    },
    {
      "key": "scum.players.read",
      "riskLevel": "medium",
      "description": "读取 SCUM 玩家列表、详情、轨迹和资产视图。"
    },
    {
      "key": "scum.players.mutate",
      "riskLevel": "high",
      "description": "提交玩家踢出、封禁、传送、技能或资产调整等高危任务。"
    },
    {
      "key": "scum.vehicles.read",
      "riskLevel": "medium",
      "description": "读取 SCUM 载具列表、归属和状态视图。"
    },
    {
      "key": "scum.vehicles.mutate",
      "riskLevel": "high",
      "description": "提交载具召回、删除、归属调整等高危任务。"
    },
    {
      "key": "scum.territories.read",
      "riskLevel": "medium",
      "description": "读取 SCUM 领地、区域和小队相关视图。"
    },
    {
      "key": "scum.territories.mutate",
      "riskLevel": "high",
      "description": "提交领地、区域或小队修正等高危任务。"
    },
    {
      "key": "scum.locks.read",
      "riskLevel": "medium",
      "description": "读取 SCUM 锁具和开锁记录视图。"
    },
    {
      "key": "scum.locks.mutate",
      "riskLevel": "high",
      "description": "提交开锁、锁具修正或锁具删除等高危任务。"
    },
    {
      "key": "scum.gifts.read",
      "riskLevel": "medium",
      "description": "读取 SCUM 礼包规则、发放记录和统计。"
    },
    {
      "key": "scum.gifts.mutate",
      "riskLevel": "high",
      "description": "创建、修改、删除或发放 SCUM 礼包规则。"
    },
    {
      "key": "scum.events.read",
      "riskLevel": "medium",
      "description": "读取 SCUM 事件、事件产物和活动配置。"
    },
    {
      "key": "scum.events.mutate",
      "riskLevel": "high",
      "description": "创建、修改、删除或触发 SCUM 事件产物。"
    },
    {
      "key": "scum.economy.read",
      "riskLevel": "low",
      "description": "读取插件自有交易物品、价格和物品图片元数据。"
    },
    {
      "key": "scum.economy.mutate",
      "riskLevel": "high",
      "description": "提交交易物品、经济配置或兑换规则变更任务。"
    },
    {
      "key": "scum.logs.read",
      "riskLevel": "medium",
      "description": "读取实例范围内的 SCUM 日志目录，并优先展示常见游戏日志文件。",
      "parameters": {
        "directory": "SCUM/Saved/SaveFiles/Logs",
        "preferredFiles": [
          "admin.log",
          "chat.log",
          "economy.log",
          "event_kill.log",
          "famepoints.log",
          "gameplay.log",
          "kill.log",
          "login.log",
          "violations.log",
          "vehicle_destruction.log"
        ]
      }
    },
    {
      "key": "scum.steam.read",
      "riskLevel": "low",
      "description": "读取 Steam 新闻和版本元数据。"
    },
    {
      "key": "scum.update.mutate",
      "riskLevel": "high",
      "description": "提交 SteamCMD 安装、服务端更新或更新计划任务。"
    },
    {
      "key": "scum.restart.mutate",
      "riskLevel": "high",
      "description": "提交实例受控重启或计划重启任务。"
    },
    {
      "key": "scum.tasks.read",
      "riskLevel": "medium",
      "description": "读取 SCUM 插件提交的任务状态、结果摘要和稳定错误。"
    }
  ],
