{
  "schemaVersion": "scum-plugin.v1",
  "pluginId": "scum-admin",
  "name": "SCUM Admin",
  "version": "0.1.18",
  "channel": "dev",
  "compatibility": {
    "minScumServerVersion": "1.0.0",
    "maxScumServerVersion": "2.0.0"
  },
  "runtime": {
    "image": "npc0/scum-admin-plugin:v0.1.18",
    "internalPorts": [],
    "exposedPorts": [],
    "portMappings": [],
    "mounts": [],
    "privileged": false,
    "hostNetwork": false
  },
  "capabilities": [
    {
      "key": "file.read",
      "version": "1",
      "riskLevel": "medium",
      "parameters": {
        "execution": "bound-run-endpoint",
        "bounded": true
      }
    },
    {
      "key": "file.patch",
      "version": "1",
      "riskLevel": "high",
      "parameters": {
        "execution": "bound-run-endpoint",
        "requiresChecksum": true
      }
    },
    {
      "key": "db.query",
      "version": "1",
      "riskLevel": "medium",
      "parameters": {
        "execution": "bound-run-endpoint",
        "readOnly": true,
        "bounded": true
      }
    },
    {
      "key": "log.read",
      "version": "1",
      "riskLevel": "medium",
      "parameters": {
        "execution": "bound-run-endpoint",
        "bounded": true
      }
    },
    {
      "key": "process.control",
      "version": "1",
      "riskLevel": "high",
      "parameters": {
        "execution": "bound-run-endpoint",
        "requiresConfirmation": true
      }
    },
    {
      "key": "steam.news",
      "version": "1",
      "riskLevel": "low",
      "parameters": {
        "execution": "plugin-runtime"
      }
    },
    {
      "key": "steamcmd.update",
      "version": "1",
      "riskLevel": "high",
      "parameters": {
        "execution": "bound-run-endpoint",
        "requiresConfirmation": true
      }
    },
    {
      "key": "task.query",
      "version": "1",
      "riskLevel": "medium",
      "parameters": {
        "execution": "bound-run-endpoint",
        "bounded": true
      }
    },
    {
      "key": "task.run",
      "version": "1",
      "riskLevel": "high",
      "parameters": {
        "execution": "bound-run-endpoint",
        "requiresConfirmation": true
      }
    },
    {
      "key": "artifact.read",
      "version": "1",
      "riskLevel": "low",
      "parameters": {
        "scope": "plugin-owned-assets"
      }
    }
  ],
  "permissions": [
    {
      "key": "scum.config.read",
      "riskLevel": "medium",
      "description": "读取 SCUM 实例配置工作区与结构化配置字段。",
      "parameters": {
        "requiresScope": true,
        "paths": [
          "ServerSettings.ini",
          "GameUserSettings.ini"
        ]
      }
    },
    {
      "key": "scum.config.patch",
      "riskLevel": "high",
      "description": "提交 SCUM 配置文件补丁并要求显式确认。",
      "parameters": {
        "requiresScope": true,
        "requiresChecksum": true,
        "paths": [
          "ServerSettings.ini",
          "GameUserSettings.ini"
        ]
      }
    },
    {
      "key": "scum.database.query",
      "riskLevel": "medium",
      "description": "对绑定执行端上的 SCUM.db 发起只读有界查询。",
      "parameters": {
        "requiresScope": true,
        "readOnly": true,
        "maxRows": 500,
        "timeoutMs": 10000
      }
    },
    {
      "key": "scum.players.read",
      "riskLevel": "medium",
      "description": "读取玩家列表、详情、登录历史、轨迹与资产信息。",
      "parameters": {
        "requiresScope": true,
        "domains": [
          "players"
        ]
      }
    },
    {
      "key": "scum.players.mutate",
      "riskLevel": "high",
      "description": "提交玩家踢出、封禁、传送与发物品等高风险任务。",
      "parameters": {
        "requiresScope": true,
        "requiresConfirmation": true,
        "domains": [
          "players"
        ]
      }
    },
    {
      "key": "scum.vehicles.read",
      "riskLevel": "medium",
      "description": "读取载具列表、归属与详情信息。",
      "parameters": {
        "requiresScope": true,
        "domains": [
          "vehicles"
        ]
      }
    },
    {
      "key": "scum.vehicles.mutate",
      "riskLevel": "high",
      "description": "提交载具召回、删除与归属调整任务。",
      "parameters": {
        "requiresScope": true,
        "requiresConfirmation": true,
        "domains": [
          "vehicles"
        ]
      }
    },
    {
      "key": "scum.territories.read",
      "riskLevel": "medium",
      "description": "读取领地、区域与小队视图数据。",
      "parameters": {
        "requiresScope": true,
        "domains": [
          "territories",
          "squads"
        ]
      }
    },
    {
      "key": "scum.territories.mutate",
      "riskLevel": "high",
      "description": "提交领地修正与相关治理任务。",
      "parameters": {
        "requiresScope": true,
        "requiresConfirmation": true,
        "domains": [
          "territories"
        ]
      }
    },
    {
      "key": "scum.locks.read",
      "riskLevel": "medium",
      "description": "读取锁具列表与开锁记录。",
      "parameters": {
        "requiresScope": true,
        "domains": [
          "locks"
        ]
      }
    },
    {
      "key": "scum.locks.mutate",
      "riskLevel": "high",
      "description": "提交锁具修正与开锁相关高风险任务。",
      "parameters": {
        "requiresScope": true,
        "requiresConfirmation": true,
        "domains": [
          "locks"
        ]
      }
    },
    {
      "key": "scum.gifts.read",
      "riskLevel": "medium",
      "description": "读取礼包规则、发放记录与统计摘要。",
      "parameters": {
        "requiresScope": true,
        "domains": [
          "gifts"
        ]
      }
    },
    {
      "key": "scum.gifts.mutate",
      "riskLevel": "high",
      "description": "提交礼包创建、修改、删除与发放任务。",
      "parameters": {
        "requiresScope": true,
        "requiresConfirmation": true,
        "domains": [
          "gifts"
        ]
      }
    },
    {
      "key": "scum.events.read",
      "riskLevel": "medium",
      "description": "读取事件规则、活动配置与产物摘要。",
      "parameters": {
        "requiresScope": true,
        "domains": [
          "events"
        ]
      }
    },
    {
      "key": "scum.events.mutate",
      "riskLevel": "high",
      "description": "提交事件生产、修改与删除任务。",
      "parameters": {
        "requiresScope": true,
        "requiresConfirmation": true,
        "domains": [
          "events"
        ]
      }
    },
    {
      "key": "scum.economy.read",
      "riskLevel": "low",
      "description": "读取交易物品常量、资源索引与插件自有图片资源。",
      "parameters": {
        "requiresScope": false,
        "domains": [
          "economy"
        ]
      }
    },
    {
      "key": "scum.economy.mutate",
      "riskLevel": "high",
      "description": "提交经济参数与交易物品相关变更任务。",
      "parameters": {
        "requiresScope": true,
        "requiresConfirmation": true,
        "domains": [
          "economy"
        ]
      }
    },
    {
      "key": "scum.logs.read",
      "riskLevel": "medium",
      "description": "读取日志工作区与日志文件元数据。",
      "parameters": {
        "requiresScope": true,
        "bounded": true,
        "domains": [
          "logs"
        ]
      }
    },
    {
      "key": "scum.steam.read",
      "riskLevel": "low",
      "description": "读取 Steam 新闻、版本元数据与发布提示。",
      "parameters": {
        "requiresScope": false,
        "domains": [
          "steam"
        ]
      }
    },
    {
      "key": "scum.update.mutate",
      "riskLevel": "high",
      "description": "提交 SteamCMD 安装与服务端更新任务。",
      "parameters": {
        "requiresScope": true,
        "requiresConfirmation": true,
        "domains": [
          "update"
        ]
      }
    },
    {
      "key": "scum.restart.mutate",
      "riskLevel": "high",
      "description": "提交受控重启任务并要求显式确认。",
      "parameters": {
        "requiresScope": true,
        "requiresConfirmation": true,
        "domains": [
          "restart"
        ]
      }
    },
    {
      "key": "scum.tasks.read",
      "riskLevel": "medium",
      "description": "读取 SCUM 插件任务状态、结果摘要与稳定错误。",
      "parameters": {
        "requiresScope": true,
        "domains": [
          "tasks"
        ]
      }
    }
  ],
